# Telegram bot (@BotFather → New Bot → API token)
# Security: keep only in .env (gitignored). Do not commit, post in chat, or put in CI logs.
# Webhook setup requires a public HTTPS URL to this app (e.g. ngrok, cloudflared, or deploy).
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Optional but recommended: same value as setWebhook(secret_token=...). If set, requests must
# include header X-Telegram-Bot-Api-Secret-Token with this value.
TELEGRAM_WEBHOOK_SECRET=

# OpenAI: один и тот же API-ключ для всех вызовов (Whisper — это не отдельный ключ, тот же OPENAI_API_KEY).
# При отсутствии ключа транскрипция в коде — заглушка.
OPENAI_API_KEY=your_openai_api_key_here

# Модель распознавания речи через OpenAI Audio API (whisper-1)
SPEECH_MODEL=whisper-1

# --- Эталоны для оценки ---
# Приоритет: Google Sheets (лист эталонов — GOOGLE_SHEET_IDEAL_TAB), иначе JSON/строка ниже.
#
# Запись результатов в Google Sheets (ФИО, дата, оценка, транскрипт, обоснование) работает только если заданы
# ОБА: путь к ключу сервисного аккаунта И id таблицы (GOOGLE_SHEET_ID или карта дисциплин ниже).
# Без них оценки уходят только в Telegram (см. логи: «Результаты в Google Sheets не записаны»).
# Таблицу расшарьте на email сервисного аккаунта из JSON с правом Editor (или Owner).
#
# Путь к JSON ключу сервисного аккаунта Google (или стандартная переменная GOOGLE_APPLICATION_CREDENTIALS).
GOOGLE_SHEETS_CREDENTIALS=
# Одна таблица на всё приложение (ID из URL: .../spreadsheets/d/ЭТОТ_ID/edit)
GOOGLE_SHEET_ID=
# Несколько дисциплин — одна строка JSON: короткий slug → id таблицы (5 дисциплин = 5 пар).
# Если в JSON больше одного slug — в боте после выбора языка показывается выбор дисциплины; иначе DEFAULT_DISCIPLINE.
# DISCIPLINE_GOOGLE_SHEET_IDS_JSON={"it_med":"1V7S6MgpF0uGNR5zNbhCoUgY5GhjR8383Ce6cWX0LrKY","math":"другой_id"}
DISCIPLINE_GOOGLE_SHEET_IDS_JSON=
DEFAULT_DISCIPLINE=default
# Имя вкладки с эталонами (должно совпадать с именем вкладки в Google Таблице)
GOOGLE_SHEET_IDEAL_TAB=ideal_answers
# Лист для append результатов: имя вкладки (например students_answers) должно совпадать с вкладкой в таблице.
# Шапка A–J (при пустом листе): ID сообщения (Telegram), ID в Telegram, …; «Номер билета» — из фраз «билет 14», «номер билета: 3» в ответе.
# Без GOOGLE_SHEET_ID (или карты дисциплин) строки в таблицу не пишутся — только ответ в Telegram.
GOOGLE_SHEET_RESULTS_TAB=students_answers

# Fallback без Sheets: один ключ или JSON (если Sheets недоступны или пусто)
MVP_QUESTION_KEY=Q1
MVP_REFERENCE_ANSWER=Краткий эталонный ответ для проверки (замените на свой).
MVP_REFERENCES_JSON=
# При true (по умолчанию) после неудачных эвристик вызывается LLM — список ключей из таблицы/.env, без шаблонов бланка.
MVP_SEGMENTATION_USE_LLM=true
# Оценка: rubric — по полям (чат) | similarity — семантика по эмбеддингам 0–1 (оба варианта — OPENAI_API_KEY)
MVP_EVALUATION_MODE=rubric
MVP_EVALUATION_MODEL=gpt-4o-mini
MVP_EMBEDDING_MODEL=text-embedding-3-small

# Очередь (опционально): если задано — вебхук Telegram ставит задачу в Redis, обработку делает процесс arq.
# 1) Поднять Redis: docker compose -f docker-compose.redis.yml up -d
# 2) Одна строка для API (uvicorn) и для воркера (arq) — из корня проекта, один и тот же .env:
REDIS_URL=redis://127.0.0.1:6379/0
# Чтобы работать без очереди (как раньше), очистите значение: REDIS_URL=

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false
